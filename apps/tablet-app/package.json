{
  "name": "tablet-app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "android:prebuild": "expo prebuild --platform android --clean",
    "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "type-check": "tsc --noEmit --project tsconfig.json --skipLibCheck",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "validate": "pnpm type-check && pnpm lint && pnpm format:check && pnpm test",
    "check:all": "pnpm type-check && pnpm lint:fix && pnpm format:fix && pnpm test:coverage"
  },
  "dependencies": {
    "@expo/config-plugins": "^55.0.7",
    "@sw/data-sync-native-kotlin": "workspace:*",
    "@sw/ui-core": "workspace:*",
    "expo": "~55.0.8",
    "expo-dev-client": "^55.0.19",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-native": "0.83.4"
  },
  "devDependencies": {
    "@types/react": "19.2.0",
    "typescript": "5.9.3"
  },
  "private": true
}
